{
	"schemaVersion": 1,
	"id": "omers-clock",
	"version": "${version}",
	"name": "Omer's Clock",
	"description": "This is a simple mod that shows you the real time while you are in game.",
	"authors": [
		"Omerr"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/omers-clock/RabbitClockIcon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.omer.OmersClock"
		],
		"client": [
			"com.omer.OmersClockClient"
		]
	},
	"mixins": [
		"omers-clock.mixins.json",
		{
			"config": "omers-clock.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}